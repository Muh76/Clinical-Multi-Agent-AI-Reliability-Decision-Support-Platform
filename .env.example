# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Clinical AI Reliability & Decision Intelligence Platform"
APP_VERSION=0.1.0
ENVIRONMENT=local
APP_DEBUG=false
APP_SECRET_KEY=

# Keep API docs disabled in production.
ENABLE_DOCS=true

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
RUN_MIGRATIONS=false

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=clinical_ai
POSTGRES_PASSWORD=clinical_ai
POSTGRES_DB=clinical_ai
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://clinical_ai:clinical_ai@clinical-ai-postgres:5432/clinical_ai
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://clinical-ai-redis:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_KEY_PREFIX=clinical_ai

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
OTEL_SERVICE_NAME=clinical-ai-api
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
METRICS_ENABLED=true
TRACING_ENABLED=true

# -----------------------------------------------------------------------------
# Future LLM Providers
# -----------------------------------------------------------------------------
# Supported values: none, openai, azure_openai, anthropic, local
LLM_PROVIDER=none
LLM_DEFAULT_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# Vector Retrieval
# -----------------------------------------------------------------------------
# Supported values: none, pgvector, qdrant, pinecone
VECTOR_PROVIDER=qdrant
VECTOR_DATABASE_URL=http://clinical-ai-qdrant:6333
VECTOR_DATABASE_API_KEY=
VECTOR_COLLECTION_PREFIX=clinical_ai
VECTOR_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# -----------------------------------------------------------------------------
# Future Agent Systems
# -----------------------------------------------------------------------------
AGENTS_ENABLED=true
AGENT_MAX_CONCURRENT_RUNS=10
AGENT_RUN_TIMEOUT_SECONDS=900
AGENT_MEMORY_TTL_SECONDS=86400
WORKFLOW_STATE_TTL_SECONDS=86400

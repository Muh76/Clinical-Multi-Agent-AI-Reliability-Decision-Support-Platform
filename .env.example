APP_NAME="Clinical AI Reliability & Decision Intelligence Platform"
APP_VERSION=0.1.0
ENVIRONMENT=local
ENABLE_DOCS=true

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
RUN_MIGRATIONS=false

POSTGRES_USER=clinical_ai
POSTGRES_PASSWORD=clinical_ai
POSTGRES_DB=clinical_ai
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://clinical_ai:clinical_ai@clinical-ai-postgres:5432/clinical_ai

REDIS_PORT=6379
REDIS_URL=redis://clinical-ai-redis:6379/0

LOG_LEVEL=INFO
LOG_JSON=true
OTEL_SERVICE_NAME=clinical-ai-api
OTEL_EXPORTER_OTLP_ENDPOINT=
